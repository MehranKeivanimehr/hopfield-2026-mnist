{
  "seed": 1337,
  "device": "cuda",
  "output_dir": "artifacts/baseline",
  "num_workers": 4,
  "sequence_path": "data/sample_sequence.json",
  "batch_size": 8,
  "epochs_per_task": 2,
  "learning_rate": 0.0001,
  "weight_decay": 0.01,
  "max_question_length": 48,
  "image_size": 224,
  "vision_backbone": "resnet18",
  "text_backbone": "distilbert-base-uncased",
  "hidden_dim": 256,
  "dropout": 0.1,
  "lambda_vis_anchor": 0.25,
  "lambda_lang_anchor": 0.25,
  "lambda_align": 0.1,
  "lambda_replay": 0.25,
  "memory_budget_per_task": 64,
  "prototype_decay": 0.9,
  "save_every_task": true
}
