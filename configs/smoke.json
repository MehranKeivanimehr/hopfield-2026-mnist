{
  "seed": 1337,
  "device": "cpu",
  "output_dir": "artifacts/smoke",
  "num_workers": 0,
  "sequence_path": "data/sample_sequence.json",
  "batch_size": 2,
  "epochs_per_task": 10,
  "learning_rate": 0.001,
  "weight_decay": 0.0,
  "max_question_length": 16,
  "image_size": 64,
  "vision_backbone": "tiny_cnn",
  "text_backbone": "hash",
  "hidden_dim": 64,
  "dropout": 0.1,
  "lambda_vis_anchor": 0.25,
  "lambda_lang_anchor": 0.25,
  "lambda_align": 0.1,
  "lambda_replay": 0.25,
  "memory_budget_per_task": 16,
  "prototype_decay": 0.9,
  "save_every_task": false,
  "pretrained_vision": false,
  "freeze_backbones": false
}
